# ============================================================
# EduSocial Backend — Environment Variables
# Copy file này thành .env và điền giá trị thực
# ============================================================

# Server
HOST=localhost
PORT=5001
APP_URL=http://localhost:5001
NODE_ENV=development

# Neo4j Database
NEO4J_URI=neo4j+s://0d7936d0.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=7d

# Cloudinary (File Upload)
CLOUDINARY_CLOUD_NAME=dpdibgisx
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_app_password
MAIL_FROM="EduSocial <no-reply@example.com>"


# Client URLs
CLIENT_URL=http://localhost:5173
RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
