{
  "name": "edusocial-backend",
  "version": "1.0.0",
  "description": "EduSocial Backend API — Express + TypeScript + Neo4j + Socket.IO",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "test": "jest --runInBand --passWithNoTests",
    "clean": "node -e \"const fs=require('fs');const p='dist';if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});console.log('Cleaned dist/')\"",
    "db:seed": "ts-node src/db/seed.ts",
    "db:ensure-admin": "ts-node src/db/ensureAdmin.ts",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed:cloudinary-images": "ts-node src/db/seedCloudinaryImages.ts",
    "db:assign:cloudinary-random": "ts-node src/db/assignFromCloudinary.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "neo4j-driver": "^5.27.0",
    "nodemailer": "^6.9.16",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
