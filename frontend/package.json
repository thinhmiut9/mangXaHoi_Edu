{
    "name":  "edusocial-frontend",
    "version":  "1.0.0",
    "description":  "EduSocial Frontend — React + Vite + TypeScript + TailwindCSS",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "preview":  "vite preview",
                    "lint":  "eslint src --ext .ts,.tsx --max-warnings 0",
                    "test":  "vitest run --passWithNoTests",
                    "clean":  "node -e \"const fs=require(\u0027fs\u0027);[\u0027dist\u0027,\u0027.vite\u0027].forEach(p=\u003e{if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true})});console.log(\u0027Cleaned\u0027)\""
                },
