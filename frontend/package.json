                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1",
                         "react-hook-form":  "^7.54.2",
                         "react-router-dom":  "^7.1.1",
                         "recharts":  "^2.15.0",
                         "socket.io-client":  "^4.8.1",
                         "tailwind-merge":  "^2.6.0",
                         "zustand":  "^5.0.3",
